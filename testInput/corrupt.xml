<?xml version="1.0" encoding="UTF-8"?>
<ROOT>
    <!-- VALID NODE: This one is fine -->
    <CAMPUS>
        <NAME>Middelheim</NAME>
        <IDENTIFIER>CMI</IDENTIFIER>
    </CAMPUS>

    <!-- STRUCTURAL ERROR 1: Mismatched closing tag -->
    <BUILDING>
        <NAME>G-Gebouw</NAME>
        <IDENTIFIER>G.1</IDENTIFIER>
        <CAMPUS>CMI</CAMPUS>
    </BUILDIN>

    <!-- DOMAIN ERROR 1 & 2: Empty NAME tag and invalid CAPACITY data type -->
    <!-- Triggers ParseRoom_EmptyTags and ParseRoom_InvalidCapacity -->
    <ROOM>
        <NAME></NAME>
        <IDENTIFIER>A.01</IDENTIFIER>
        <CAPACITY>abc</CAPACITY>
    </ROOM>

    <!-- DOMAIN ERROR 3: CO2 value is negative -->
    <!-- Triggers EXPECT_DEATH in TestCO2PreconditionViolation -->
    <CATERING>
        <CAMPUS>CMI</CAMPUS>
        <CO2>-5.0</CO2>
    </CATERING>

    <!-- STRUCTURAL ERROR 2: Missing closing angle bracket on <DATE> -->
    <!-- Triggers MakeRoot_AfterFileError due to broken open tag -->
    <MEETING>
        <LABEL>Projectoverleg</LABEL>
        <IDENTIFIER>M001</IDENTIFIER>
        <ROOM>A.01</ROOM>
        <DATE>2024-05-12</DATE
    </MEETING>

    <!-- DOMAIN ERROR 4: Missing mandatory tags -->
    <!-- Triggers ParseParticipation_EmptyTags -->
    <PARTICIPATION>
        <USER></USER>
        <MEETING></MEETING>
    </PARTICIPATION>

    <!-- DOMAIN ERROR 5: Invalid time format -->
    <!-- Triggers InputInvalidTimeFormat -->
    <RENOVATION>
        <ROOM>G.1.01</ROOM>
        <START>25:61</START>
        <END>12:00</END>
    </RENOVATION>

    <!-- STRUCTURAL ERROR 3: Missing closing </ROOT> tag -->